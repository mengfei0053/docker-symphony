# Copy to .env and edit before starting:
#   cp .env.example .env

# Required for Linear-backed workflows.
LINEAR_API_KEY=

# Optional: override values referenced by config/WORKFLOW.md.
# Linear project slug from the Linear project URL.
LINEAR_PROJECT_SLUG=

# Repository Symphony should clone for issue workspaces.
SOURCE_REPO_URL=git@github.com:your-org/your-repo.git
# Branch Symphony should clone for issue workspaces.
SOURCE_REPO_BRANCH=main

# Codex command used by Symphony. The Dockerfile installs @openai/codex globally.
CODEX_BIN=codex

# Required by Codex config when requires_openai_auth = true.
# Use the token/key expected by your OpenAI-compatible gateway.
OPENAI_API_KEY=

# Optional: Figma Personal Access Token for Codex Figma MCP.
# Create at Figma Settings -> Security -> Personal access tokens (read-only is enough).
FIGMA_API_KEY=
