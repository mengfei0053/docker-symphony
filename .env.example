# Copy to .env and edit before starting:
#   cp .env.example .env

# Required for Linear-backed workflows.
LINEAR_API_KEY=

# Optional: override values referenced by config/WORKFLOW.md.
# Linear project slug from the Linear project URL.
LINEAR_PROJECT_SLUG=

# Repository Symphony should clone for issue workspaces.
SOURCE_REPO_URL=git@github.com:your-org/your-repo.git

# Codex command used by Symphony. The Dockerfile installs @openai/codex globally.
CODEX_BIN=codex

# Optional: if your Codex CLI or provider uses an API key, provide it here.
# OPENAI_API_KEY=
